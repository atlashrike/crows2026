# add read groups for each sra run
rule add_read_groups:
    input:
        "02_mapped/bam_sorted/{sra_id}.sorted.bam"
    output:
        "03_readgrp/{sra_id}.bam"
    params:
        rgid = lambda w: w.sra_id,                         # RGID
        rgsm = lambda w: sra_to_individual[w.sra_id],      # RGSM
        rglb = lambda w: rglb_for(w.sra_id),               # RGLB (from library_info.tsv if available)
        rgpl = "ILLUMINA",                                 # RGPL
        rgpu = lambda w: w.sra_id                          # RGPU (use flowcell.lane if you know it)
    threads: 4
    shell:
        r"""
        mkdir -p 03_readgrp
        gatk AddOrReplaceReadGroups \
            -I {input} \
            -O {output} \
            -RGID {params.rgid} \
            -RGSM {params.rgsm} \
            -RGLB {params.rglb} \
            -RGPL {params.rgpl} \
            -RGPU {params.rgpu}
        """


