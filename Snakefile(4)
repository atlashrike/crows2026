rule poplabels:
    input:
        sample = "09_relate/per_chrom/" + LD_PHASE_CHROMS[0] + "/134inds.sample",
        poplist = POPLIST
    output:
        poplabels = "09_relate/poplabels.txt"
    run:
        pop_map = {}
        with open(input.poplist) as f:
            next(f)
            for line in f:
                parts = line.strip().split('\t')
                if len(parts) >= 4:
                    sample_id = parts[3]
                    pop = parts[1]
                    taxa = parts[2]
                    pop_map[sample_id] = (pop, taxa)

        with open(input.sample) as f, open(output.poplabels, 'w') as out:
            out.write("sample population group sex\n")
            next(f)  # skip header
            next(f)  # skip dummy line
            for line in f:
                parts = line.strip().split()
                sample = parts[0]
                if sample in pop_map:
                    pop, taxa = pop_map[sample]
                    # assign group based on taxa
                    if taxa == "C.corone":
                        group = "corone"
                    elif taxa == "C.cornix":
                        group = "cornix"
                    elif taxa == "C.orientalis":
                        group = "orientalis"
                    elif taxa == "C.pallescens":
                        group = "pallescens"
                    elif taxa == "C.capellanus":
                        group = "capellanus"
                    elif taxa == "Hybrid":
                        group = "hybrid"
                    else:
                        group = taxa.replace("C.", "").lower()
                    out.write(f"{sample}_1 {pop} {group} 1\n")
                    out.write(f"{sample}_2 {pop} {group} 1\n")

