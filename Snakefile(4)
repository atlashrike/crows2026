            -R {REF_GENOME} \
            -I {output.bam} \
            -O {output.stats} \
            --METRIC_ACCUMULATION_LEVEL SAMPLE \
            --METRIC_ACCUMULATION_LEVEL READ_GROUP

        # Cleanup intermediate
        rm -f 04_markdup/{wildcards.individual}_markdup.bam
        """
