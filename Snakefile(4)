# shared times and coalescence times
rule time2:
    input:
        newick = "09_relate/trees2/{chrom}_{start}-{stop}.newick"
    output:
        stss = "09_relate/trees2/{chrom}_{start}-{stop}._sts.npy",
        ctss = "09_relate/trees2/{chrom}_{start}-{stop}._cts.npy"
    threads: 1
    run:
        from tsconvert.newick import from_newick
        from utils import get_shared_times
        import numpy as np
        from tqdm import tqdm

        stss = []
        ctss = []
        with open(input.newick, mode='r') as f:
            next(f)  # skip header
            for line in tqdm(f, total=NUM_SAMPLES):
                string = line.split()[4]
                ts = from_newick(string, min_edge_length=1e-6)
                tree = ts.first()

                samples = [int(ts.node(node).metadata['name']) for node in ts.samples()]
                sample_order = np.argsort(samples)
                ordered_samples = [ts.samples()[i] for i in sample_order]
                sts = get_shared_times(tree, ordered_samples)
                stss.append(sts)

                cts = sorted([tree.time(i) for i in tree.nodes() if not tree.is_sample(i)])
                ctss.append(cts)

        np.save(output.stss, np.array(stss))
        np.save(output.ctss, np.array(ctss))


# process shared times
rule process_shared_times:
    input:
        stss = "09_relate/trees2/{chrom}_{start}-{stop}._sts.npy"
    output:
        mc_invs = "09_relate/trees2/{chrom}_{start}-{stop}_NoneT_mc-invs.npy",
        logdets = "09_relate/trees2/{chrom}_{start}-{stop}_NoneT_logdets.npy",
        samples = "09_relate/trees2/{chrom}_{start}-{stop}_NoneT_samples.npy"
    threads: 1
    run:
        import os
        os.environ["OMP_NUM_THREADS"] = str(threads)

        import numpy as np
        from utils import chop_shared_times, center_shared_times

        stss = np.load(input.stss)
        
        stss_inv = []
        stss_logdet = []
        smplsss = []
        tCutoff = None
        
        for sts in stss:
            sts_chopped, smpls = chop_shared_times(sts, tCutoff=tCutoff)
            sts_inv = []
            sts_logdet = []
            smplss = []
            
            for st, sm in zip(sts_chopped, smpls):
                stc = center_shared_times(st)
                stc_inv = np.linalg.pinv(stc)
                stc_logdet = np.linalg.slogdet(st)[1]
                sts_inv.append(stc_inv)
                sts_logdet.append(stc_logdet)
                smplss.append(sm)
            
            stss_inv.append(sts_inv)
            stss_logdet.append(sts_logdet)
            smplsss.append(smplss)
        
        np.save(output.mc_invs, np.array(stss_inv, dtype=object))
        np.save(output.logdets, np.array(stss_logdet, dtype=object))
        np.save(output.samples, np.array(smplsss, dtype=object))

# process coalescence times
rule process_coal_times:
    input:
        ctss = "09_relate/trees2/{chrom}_{start}-{stop}._cts.npy",
        coal = "09_relate/popsize/{chrom}/134inds.coal"
    output:
        bts = "09_relate/trees2/{chrom}_{start}-{stop}_NoneT_bts.npy",
        lpcs = "09_relate/trees2/{chrom}_{start}-{stop}_NoneT_lpcs.npy"
    threads: 1
    run:
        import os
        os.environ["OMP_NUM_THREADS"] = str(threads)

        import numpy as np
        from spacetrees import _log_coal_density

        epochs = np.genfromtxt(input.coal, skip_header=1, skip_footer=1)
        Nes = 0.5 / np.genfromtxt(input.coal, skip_header=2)[2:]

        ctss = np.load(input.ctss)
        btss = []
        lpcs = []
        tCutoff = None

        for cts in ctss:
            cts = np.array(cts)
            T = cts[-1] if len(cts) > 0 else 0
            if tCutoff is not None and tCutoff < T:
                T = tCutoff
            bts = T - np.flip(cts)
            bts = bts[bts > 0]
            bts = np.append(bts, T)
            btss.append(bts)

            lpc = _log_coal_density(times=cts, Nes=Nes, epochs=epochs, tCutoff=tCutoff)
            lpcs.append(lpc)

        np.save(output.bts, np.array(btss, dtype=object))
        np.save(output.lpcs, np.array(lpcs, dtype=object))

