rule vcf2ldhelmet_fasta:
    input:
        vcf = "10_ldhelmet/vcfs/swed_{chrom}.vcf.gz"
    output:
        fasta = "10_ldhelmet/input/{chrom}.FINAL_INPUT.fasta",
        pos = "10_ldhelmet/input/{chrom}.snp.pos.file"
    shell:
        r"""
        mkdir -p 10_ldhelmet/input
        
        vcftools \
            --gzvcf {input.vcf} \
            --plink \
            --out 10_ldhelmet/input/{wildcards.chrom}

        ./plink \
            --ped 10_ldhelmet/input/{wildcards.chrom}.ped \
            --map 10_ldhelmet/input/{wildcards.chrom}.map \
            --recode fastphase \
            --out 10_ldhelmet/input/{wildcards.chrom}

        cd 10_ldhelmet/input/

        phasefile="{wildcards.chrom}.chr-0.recode.phase.inp"

        grep '^P' "$phasefile" \
            | sed 's/ /\n/g' \
            | tail -n +2 > {wildcards.chrom}.snp.pos.file

        tail -n +4 "$phasefile" \
            | sed 's/#/>/g' \
            | sed 's/ /_/g' > {wildcards.chrom}.temp

        grep '>' {wildcards.chrom}.temp > {wildcards.chrom}.ID_1
        awk '{{print $1 "_2"}}' {wildcards.chrom}.ID_1 > {wildcards.chrom}.ID_2

        sed -n '2~3p' {wildcards.chrom}.temp > {wildcards.chrom}.H1
        sed -n '3~3p' {wildcards.chrom}.temp > {wildcards.chrom}.H2

        paste {wildcards.chrom}.ID_1 {wildcards.chrom}.H1 \
            | tr "\t" "\n" > {wildcards.chrom}.ID_1_H1
        paste {wildcards.chrom}.ID_2 {wildcards.chrom}.H2 \
            | tr "\t" "\n" > {wildcards.chrom}.ID_2_H2

        cat {wildcards.chrom}.ID_1_H1 {wildcards.chrom}.ID_2_H2 \
            > {wildcards.chrom}.FINAL_INPUT.fasta

        rm -f {wildcards.chrom}.ID_1 \
              {wildcards.chrom}.ID_2 \
              {wildcards.chrom}.H1 \
              {wildcards.chrom}.H2 \
              {wildcards.chrom}.ID_1_H1 \
              {wildcards.chrom}.ID_2_H2 \
              {wildcards.chrom}.temp \
              {wildcards.chrom}.ped \
              {wildcards.chrom}.map \
              {wildcards.chrom}.chr-0.recode.phase.inp
        """

