rule filter_paralogs_hwe:
    input:
        vcf = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats.vcf.gz",
        cnx3_pop = "05.1_recal/overlap/cnx3.pop"
    output:
        cnx3_vcf = temp("05.1_recal/overlap/134inds_overlapped_filtered_norepeats_cnx3.recode.vcf"),
        hwe = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats_cnx3.hwe",
        hwe_pos = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats_cnx3_hwedis.pos",
        filtered_vcf = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats_hwe.vcf.gz",
        filtered_idx = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats_hwe.vcf.gz.csi"
    params:
        hwe_pval = 0.05,
        exclude_chrom = "NC_046347.1"  # chr18
    threads: 8
    shell:
        r"""
        set -euo pipefail
        mkdir -p 05.1_recal/overlap

        # Subset to cnx3 population
        vcftools --gzvcf {input.vcf} \
            --keep {input.cnx3_pop} \
            --recode --out 05.1_recal/overlap/134inds_overlapped_filtered_norepeats_cnx3

        # Calculate Hardy-Weinberg statistics
        vcftools --vcf {output.cnx3_vcf} \
            --hardy --out 05.1_recal/overlap/134inds_overlapped_filtered_norepeats_cnx3

        # Extract positions that deviate from HWE (p < 0.05), excluding chr18
        awk 'NR>1 && $6<{params.hwe_pval} {{print $1, $2}}' {output.hwe} \
            | grep -v "^{params.exclude_chrom} " \
            > {output.hwe_pos}

        # Count sites being removed
        echo "HWE-deviant sites to remove (excluding chr18): $(wc -l < {output.hwe_pos})"

        # Remove HWE-deviant sites from the full VCF
        vcftools --gzvcf {input.vcf} \
            --exclude-positions {output.hwe_pos} \
            --recode --out 05.1_recal/overlap/134inds_overlapped_filtered_norepeats_hwe

        # Compress and index
        bcftools view -Oz -o {output.filtered_vcf} \
            05.1_recal/overlap/134inds_overlapped_filtered_norepeats_hwe.recode.vcf
        bcftools index -c {output.filtered_vcf}

        # Cleanup
        rm -f 05.1_recal/overlap/134inds_overlapped_filtered_norepeats_hwe.recode.vcf

        # Report final counts
        echo "Final SNP count after HWE filtering:"
        bcftools view -H {output.filtered_vcf} | wc -l
        """

