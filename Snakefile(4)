# trim adapters with cutadapt - step 1.1.1
rule trim_adapters:
    input:
        r1 = "fastq/{sra_id}_1.fastq.gz",
        r2 = "fastq/{sra_id}_2.fastq.gz"
    output:
        r1 = "01_trimmed/{sra_id}_trimmed.R1.fq.gz",
        r2 = "01_trimmed/{sra_id}_trimmed.R2.fq.gz"
    params:
        # add -u 5 -U 5 only for the listed individuals
        extra = lambda w: ("-u 5 -U 5" if sra_to_individual[w.sra_id] in TRIM5_INDIVIDUALS else "")
    threads: 8
    shell:
        r"""
        cutadapt -j {threads} -m 30 -q 20 \
            {params.extra} \
            -a AGATCGGAAGAGCACACGTCTGAACTCCAGTCA \
            -A AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT \
            -o {output.r1} -p {output.r2} \
            {input.r1} {input.r2}
        """

