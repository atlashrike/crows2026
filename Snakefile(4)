        """

# merge samtools scaffolds and filter
rule merge_filter_samtools:
    input:
        expand("05.1_recal/samtools/134inds/134inds_samtools_scaffold_{scaffold}.vcf.gz", 
               scaffold=CHROM)
    output:
        merged = "05.1_recal/samtools/134inds/134inds_samtools.vcf.gz",
        biallelic = "05.1_recal/samtools/134inds/134inds_samtools.V1.vcf.gz",
        filtered = "05.1_recal/samtools/134inds/samtools_DP3GQ0Miss10Q30/134inds_samtools_DP3GQ0Miss10Q30_filtered_norepeats.vcf.gz"
    threads: 128
    params:
        qual = 30,
        mq = 40,
        min_dp = 3,
        min_gq = 0,
        miss = 0.1,
        repeat_bed = REPEAT_BED
    shell:
        r"""
        set -euo pipefail
    
        # make sure parent dirs exist
        mkdir -p "$(dirname {output.merged})"
        mkdir -p "$(dirname {output.biallelic})"
        mkdir -p "$(dirname {output.filtered})"
    
        # create an explicit file list from Snakemake 'input'
        # (avoids fragile 'ls' globbing)
        tmp_list=$(mktemp)
        printf "%s\n" {input} | tr ' ' '\n' > "$tmp_list"
    
        # merge
        bcftools concat --file-list "$tmp_list" -Oz -o {output.merged} --threads {threads}
    
        # biallelic SNPs only
        bcftools view --threads {threads} -V indels --min-alleles 2 --max-alleles 2 \
            -Oz -o {output.biallelic} {output.merged}
    
        # work inside the filter directory derived from the final output path
        FILTER_DIR="$(dirname {output.filtered})"
        mkdir -p "$FILTER_DIR"
    
        # V2: info-level filters
        bcftools view --threads {threads} -Oz \
            -o "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30.V2.vcf.gz" \
            --exclude "QUAL < {params.qual} || MQ < {params.mq}" \
            {output.biallelic}
    
        # V3: genotype-level filters
        bcftools filter --threads {threads} -Oz \
            -o "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30.V3.vcf.gz" \
            --set-GTs . \
            --include "FMT/DP >= {params.min_dp} & FMT/GQ >= {params.min_gq}" \
            "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30.V2.vcf.gz"
    
        # V4: missingness filter
        bcftools view --threads {threads} -Oz \
            -o "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30_filtered.vcf.gz" \
            --include "F_MISSING <= {params.miss}" \
            "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30.V3.vcf.gz"
    
        # remove repeats
        vcftools --exclude-bed {params.repeat_bed} \
            --gzvcf "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30_filtered.vcf.gz" \
            --recode --out "$FILTER_DIR/134inds_samtools_DP3GQ0Miss10Q30_filtered_norepeats"
    
        # bgzip + index final filtered_no-repeats VCF
        bcftools view -Oz -o {output.filtered} \
