# mapdamage- step 1.3.2
rule mapdamage:
    input:
        bam = "04_markdup/{individual}_markdup_cleaned.bam",
        ref = REF_GENOME
    output:
        rescaled = "04_markdup/{individual}_markdup_cleaned.rescaled.bam",
        bai      = "04_markdup/{individual}_markdup_cleaned.rescaled.bai",
        results  = directory("04_markdup/results_{individual}")  
    threads: 2
    shell:
        r"""
        set -euo pipefail

        [ -f {input.ref}.fai ] || samtools faidx {input.ref}
        [ -f {input.bam}.bai ] || samtools index -@ {threads} {input.bam}

        rm -rf {output.results}

        mapDamage -i {input.bam} -r {input.ref} -d {output.results} -t {threads} --merge-reference-sequences
        mapDamage -i {input.bam} -r {input.ref} -d {output.results} -t {threads} --plot-only || true

        if mapDamage --help | grep -q -- "--rescale-out"; then
            mapDamage -i {input.bam} -r {input.ref} -d {output.results} -t {threads} \
                      --rescale-only --rescale-out {output.rescaled}
        else
            mapDamage -i {input.bam} -r {input.ref} -d {output.results} -t {threads} --rescale-only
            mv {output.results}/{wildcards.individual}_markdup_cleaned.rescaled.bam {output.rescaled}
        fi

        if command -v picard >/dev/null 2>&1; then
            picard BuildBamIndex INPUT={output.rescaled} OUTPUT={output.bai} VALIDATION_STRINGENCY=SILENT
        else
            samtools index -@ {threads} {output.rescaled}
        fi
        """
