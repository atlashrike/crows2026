        "/home/oven/links/scratch/crows2/containers/gatk4_4.6.2.0.sif"
    shell:
        r"""
        set -euo pipefail
        mkdir -p 04_markdup 04_markdup/00_stats

        # Build the -I arguments for MarkDuplicates
        in_args=""
        for bam in {input}; do
            in_args="$in_args -I $bam"
        done

        gatk MarkDuplicates \
            $in_args \
            -O 04_markdup/{wildcards.individual}_markdup.bam \
            -M {output.metrics} \
            --REMOVE_DUPLICATES true \
            --MAX_FILE_HANDLES_FOR_READ_ENDS_MAP 1000 \
