        mkdir -p 02_mapped/bam_sorted
        bwa mem -t {threads} -M {input.ref} {input.r1} {input.r2} > 02_mapped/{wildcards.sra_id}.sam
        samtools view -bhq 6 -@ {threads} 02_mapped/{wildcards.sra_id}.sam > 02_mapped/{wildcards.sra_id}.bam
        samtools sort -m 4G -@ {threads} 02_mapped/{wildcards.sra_id}.bam -o {output.bam}
