rule mark_duplicates:
    input:
        # all SRA run BAMs for this individual
        lambda w: expand("03_readgrp/{sra_id}.bam", sra_id=sra_data[w.individual])
    output:
        bam     = "04_markdup/{individual}_markdup_cleaned.bam",
        bai     = "04_markdup/{individual}_markdup_cleaned.bai",
        metrics = "04_markdup/{individual}_markdup.txt",
        stats   = "04_markdup/00_stats/{individual}.alignments.txt"
