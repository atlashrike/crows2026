import csv
import os

run_to_library = {}
if os.path.exists("library_info.tsv"):
    with open("library_info.tsv", newline="") as f:
        rdr = csv.DictReader(f, delimiter="\t")
        for row in rdr:
            run = (row.get("run") or "").strip()
            lib = (row.get("library_name") or "").strip()
            if run and lib:
                run_to_library[run] = lib

def rglb_for(run_id: str) -> str:
    return run_to_library.get(run_id, sra_to_individual[run_id])

