rule filter_genotyped_vcf:
    input:
        genotyped = "05.1_recal/GATKraw/134inds_chrDiploid.vcf.gz",
        repeat_bed = REPEAT_BED
    output:
        variant_only = "05.1_recal/GATKraw/134inds_varonly_chrDiploid.V1.vcf.gz",
        filtered = "05.1_recal/GATKraw/134inds_DP3GQ0Miss10fullinfoQ100/134inds_varonly_chrDiploid_DP3GQ0Miss10fullinfoQ100_filtered_norepeats.vcf.gz"
    threads: 64
    params:
        qd = 2,
        fs = 60,
        sor = 3,
        mq = 40,
        mq_ranksum = -12.5,
        readpos_ranksum = -8,
        qual = 100,
        min_dp = 3,
        min_gq = 0,
        miss = 0.1
    shell:
        """
        filter_dir="05.1_recal/GATKraw/134inds_DP3GQ0Miss10fullinfoQ100"
        mkdir -p "$filter_dir"
        prefix="$filter_dir/134inds_varonly_chrDiploid_DP3GQ0Miss10fullinfoQ100"
        
        # extract variant sites only (biallelic SNPs) from genotyped VCF
        bcftools view --threads {threads} -V indels --min-alleles 2 --max-alleles 2 \
            -Oz -o {output.variant_only} {input.genotyped}
        bcftools index {output.variant_only}
        
        # info-level filter
        bcftools view --threads {threads} -Oz \
            -o "${{prefix}}.V2.vcf.gz" \
            --exclude "QD < {params.qd} || FS > {params.fs} || SOR > {params.sor} || QUAL < {params.qual} || MQ < {params.mq} || MQRankSum < {params.mq_ranksum} || ReadPosRankSum < {params.readpos_ranksum}" \
            {output.variant_only}
        
        # genotype-level filter
        bcftools filter --threads {threads} -Oz \
            -o "${{prefix}}.V3.vcf.gz" \
            --set-GTs . \
            --include "FMT/DP >= {params.min_dp} & FMT/GQ >= {params.min_gq}" \
            "${{prefix}}.V2.vcf.gz"
        
        # remove high missingness
        bcftools view --threads {threads} -Oz \
            -o "${{prefix}}_filtered.vcf.gz" \
            --include "F_MISSING <= {params.miss}" \
            "${{prefix}}.V3.vcf.gz"
        
        # remove repeat regions
        vcftools --exclude-bed {input.repeat_bed} \
            --gzvcf "${{prefix}}_filtered.vcf.gz" \
            --recode --out "${{prefix}}_filtered_norepeats"
        
        # compress & index final VCF
        bcftools view -Oz -o {output.filtered} \
            "${{prefix}}_filtered_norepeats.recode.vcf"
        bcftools index {output.filtered}
        rm "${{prefix}}_filtered_norepeats.recode.vcf"
        """

rule find_overlap_and_filter:
    input:
        gatk = "05.1_recal/GATKraw/134inds_DP3GQ0Miss10fullinfoQ100/134inds_varonly_chrDiploid_DP3GQ0Miss10fullinfoQ100_filtered_norepeats.vcf.gz",
        samtools = "05.1_recal/samtools/134inds/samtools_DP3GQ0Miss10Q30/134inds_samtools_DP3GQ0Miss10Q30_filtered_norepeats.vcf.gz",
        angsd = "05.1_recal/angsd/merged/134inds_rescaled_angsdrecalq30mindepth400genodepth3_min121.vcf.gz",
        overlap_py = "overlap.py"
    output:
        positions = "05.1_recal/overlap/overlap_allcallers.pos",
        vcf = "05.1_recal/overlap/134inds_overlapped_filtered_norepeats.vcf.gz"
    threads: 80
    params:
        mq = 40,
        qual = 30,
        min_dp = 3,
        miss = 0.1
    shell:
        r"""
        set -euo pipefail
        mkdir -p 05.1_recal/overlap

        bcftools query -f '%CHROM %POS\n' {input.gatk}    | awk '{{print $1"_"$2}}' > 05.1_recal/overlap/gatk_pos.txt
        bcftools query -f '%CHROM %POS\n' {input.samtools}| awk '{{print $1"_"$2}}' > 05.1_recal/overlap/samtools_pos.txt
        bcftools query -f '%CHROM %POS\n' {input.angsd}   | awk '{{print $1"_"$2}}' > 05.1_recal/overlap/angsd_pos.txt

        # Python overlap (writes overlapping_variants_pos.txt)
        python3 {input.overlap_py} \
            --gatk    05.1_recal/overlap/gatk_pos.txt \
            --samtools 05.1_recal/overlap/samtools_pos.txt \
            --angsd    05.1_recal/overlap/angsd_pos.txt \
            --out      05.1_recal/overlap/overlapping_variants_pos.txt

        # Convert to vcftools --positions format (CHROM<tab>POS)
        # Split on LAST underscore since chromosome names contain underscores
        tail -n +2 05.1_recal/overlap/overlapping_variants_pos.txt | rev | sed 's/_/\t/' | rev > {output.positions}

        # Verify positions file was created correctly
        echo "First 5 lines of positions file:"
        head -5 {output.positions}
        echo "Total positions: $(wc -l < {output.positions})"

        vcftools --positions {output.positions} \
            --gzvcf {input.samtools} \
            --recode --out 05.1_recal/overlap/134inds_overlapped

        bcftools view --threads {threads} -Oz \
            -o 05.1_recal/overlap/134inds_overlapped.V1.vcf.gz \
            --exclude "QUAL < {params.qual} || MQ < {params.mq}" \
            05.1_recal/overlap/134inds_overlapped.recode.vcf

        bcftools filter --threads {threads} -Oz \
            -o 05.1_recal/overlap/134inds_overlapped.V2.vcf.gz \
            --set-GTs . \
            --include "FMT/DP >= {params.min_dp}" \
            05.1_recal/overlap/134inds_overlapped.V1.vcf.gz

        bcftools view --threads {threads} -Oz \
            -o {output.vcf} \
            --include "F_MISSING <= {params.miss}" \
            05.1_recal/overlap/134inds_overlapped.V2.vcf.gz

        bcftools index -f -c {output.vcf}
        vcftools --gzvcf {output.vcf} --freq --out 05.1_recal/overlap/134inds_overlapped_filtered_norepeats

        rm -f 05.1_recal/overlap/134inds_overlapped.recode.vcf 05.1_recal/overlap/134inds_overlapped.V*.vcf.gz
        """

def get_pop_samples(poplist_file, pop_name):
    samples = []
    with open(poplist_file) as f:
        next(f)  # skip header
        for line in f:
            parts = line.strip().split('\t')
            if len(parts) >= 2 and parts[1] == pop_name:
                samples.append(parts[0])
    return samples

